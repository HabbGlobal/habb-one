# ─── Datenbank (Supabase) ─────────────────────────────────────────────
# DATABASE_URL = pooled connection (PgBouncer, Port 6543) — von der App genutzt.
# DIRECT_URL   = direct connection (Port 5432) — nur für Prisma Migrate genutzt.
DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# ─── NextAuth v5 ──────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
# v5-konformer Name; v4-Alias NEXTAUTH_SECRET wird auch gelesen.
NEXTAUTH_SECRET="change-me-in-production"
# Auf Vercel kann diese URL leer bleiben — `trustHost: true` reicht. Lokal:
NEXTAUTH_URL="http://localhost:3000"

# ─── Public-URLs ──────────────────────────────────────────────────────
# Basis-URL für den Tracking-Link auf dem Auftrags-Etikett (gedruckt als
# "<base>/<trackingToken>"). KEIN Hardcode-Fallback: ist die Variable
# leer, wird bewusst GAR KEINE URL aufs Etikett gedruckt (nie eine
# fremde Mandanten-Domain auf fremden Dokumenten). Erst setzen, wenn die
# /track-Seite existiert. Beispiel: "https://one.HABB Global (PVT) LTD/track".
PUBLIC_TRACKING_URL=""

# ─── Seed (nur für db:seed lokal/CI; auf Vercel NICHT setzen) ─────────
SEED_ADMIN_EMAIL="admin@habb global.ch"
SEED_ADMIN_PASSWORD="admin1234"
SEED_SUPERADMIN_EMAIL="superadmin@habb global.ch"
SEED_SUPERADMIN_PASSWORD="superadmin1234"

# ─── Mail (SMTP über Zoho o.ä.) ───────────────────────────────────────
# Zoho-Beispiel (EU-Datacenter):
#   SMTP_HOST = smtp.zoho.eu
#   SMTP_PORT = 587  (STARTTLS)  oder 465 (implicit TLS)
#   SMTP_USER = support@HABB Global (PVT) LTD
#   SMTP_PASS = App-spezifisches Passwort aus accounts.zoho.com/home#security/asp
# Andere Anbieter laufen analog.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="HABB One <support@HABB Global (PVT) LTD>"
# WARN: MAIL_DEV_LOG_ONLY=true ist in PRODUCTION verboten — der Code wirft
# beim Versuch, in Prod ohne echten Versand zu laufen. Nur lokal nutzen.
MAIL_DEV_LOG_ONLY="false"

# ─── Owner Portal ─────────────────────────────────────────────────────
# Feature-Flag: schaltet das gesamte Owner-Portal /owner + /api/owner aus.
# Default: false (Portal unsichtbar) bis PR 1+ stable sind.
OWNER_PORTAL_ENABLED="false"
# Eigenes Auth-Secret für Owner-JWTs — strikt getrennt von NEXTAUTH_SECRET,
# damit ein geleakter Tenant-Secret nicht zum Owner-Token-Forging führt.
# Generate: openssl rand -base64 32
OWNER_AUTH_SECRET="change-me-in-production"
# Empfänger der internen "Neue Registrierung wartet auf Freigabe"-Mail.
# Wird ausgelöst sobald eine Self-Registration die E-Mail-Verifizierung
# bestanden hat (Status → PENDING_APPROVAL). Leer = keine Owner-Mail.
OWNER_NOTIFY_EMAIL="support@HABB Global (PVT) LTD"

# ─── Vercel Cron ──────────────────────────────────────────────────────
# Shared Secret für die täglichen Cron-Jobs (z.B. /api/cron/holidays).
# Vercel sendet bei jedem Cron-Call `Authorization: Bearer ${CRON_SECRET}`;
# der Endpoint lehnt jede Anfrage ohne dieses Header ab.
# Generate: openssl rand -base64 32
CRON_SECRET="change-me-in-production"
# Stündlicher Diagnose-Cron nutzt denselben CRON_SECRET:
#   { "path": "/api/cron/diagnostics", "schedule": "0 * * * *" }

# ─── Owner-Diagnostics / Security-Monitoring ──────────────────────────
# Empfänger der Diagnose-/Security-Mails. Leer = kein Versand
# (Phase 2). Fällt sonst auf OWNER_NOTIFY_EMAIL zurück.
DIAGNOSTICS_EMAIL_TO=""
DIAGNOSTICS_EMAIL_FROM=""
# Externe KI ist für dieses Modul VERBOTEN. Flag bleibt false; nur ein
# deaktivierter interner Seam, niemals Daten an externe LLMs.
AI_DIAGNOSTICS_ENABLED="false"
