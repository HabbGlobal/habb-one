// Tschannen Spritzwerk AG — Zeiterfassung
// Prisma schema. Design notes:
//   - One TimeEntry per employee per local date. TimePunches store raw events,
//     BreakEntries store break ranges. Calculated balances are NEVER stored
//     blindly; aggregates are computed from raw data on read.
//   - All times are stored as UTC DateTime; the application layer interprets
//     them in Europe/Zurich for display and aggregation.
//   - PIN is only stored as a bcrypt hash (`pinHash`).
//   - All mutating actions on time-relevant entities create AuditLog rows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  // Höchste Stufe — system administrator. Hat IMMER alle Rechte und ist
  // der einzige Account, der die RolePermission-Matrix bearbeiten darf.
  // Existiert genau 1× pro Firma (per Konvention; kein DB-constraint).
  SUPERADMIN
  // CEO / Geschäftsleitung. Vom SUPERADMIN per Matrix konfigurierbar.
  ADMIN
  // "Sekretärin" — Backoffice (Aufträge, Offerten, Rechnungen, Planung).
  // Intern weiterhin PLANNER (umbenannt nur das UI-Label).
  PLANNER
  // "Produktionsmitarbeiter" — Werkstatt, scant Aufträge, sieht eigene
  // Zeiten/Schichten. Kein Backoffice-Zugriff per Default.
  EMPLOYEE
  // Reserviert für späteres Kundenportal (Phase 7).
  CUSTOMER_PORTAL
  // Werkstatt-Tablet-Konto. Keine Backoffice-Rechte; loggt sich am Tablet
  // ein und landet automatisch im Stempel-Kiosk seiner Firma. Ersetzt das
  // anonyme Kiosk-Lock-Passwort durch einen echten Account.
  KIOSK_OPERATOR
  // Legacy-Werte — Daten in Migration auf PLANNER aktualisiert.
  // Werden vom Code nicht mehr benutzt, der enum-Wert bleibt aus
  // Postgres-Kompatibilitätsgründen erhalten.
  SECRETARY
  TEAM_LEAD
}

